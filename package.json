{
  "name": "express-postgres-starter",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "cd buildorbit-frontend && npm install --include=dev && npm run build && cd .. && npm run build:cli",
    "migrate": "node migrate.js",
    "test": "node scripts/run-unit-tests.js",
    "test:unit": "node scripts/run-unit-tests.js",
    "publish:cli": "cd cli && npm install && npm publish --access public",
    "build:cli": "node scripts/package-cli.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@anthropic-ai/sdk": "^0.36.3",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "helmet": "^8.0.0",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "jsdom": "^25.0.1",
    "node-fetch": "^2.7.0",
    "openai": "^4.77.0",
    "pdfkit": "^0.15.1",
    "pg": "^8.11.3",
    "playwright-core": "^1.49.1",
    "stripe": "^17.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.24.1"
  }
}
