# BuildOrbit — Environment Variables
#
# IMPORTANT: Production secrets must be configured in the platform environment
# (Render, Polsia, or equivalent), never committed to the repository. The server
# refuses to boot when required values are missing.
#
# See README.md for the production deploy checklist.
#
# ── AI / LLM ─────────────────────────────────────────────────────────────────
#
# OpenAI API key. Required unless MOCK_MODE=true. MOCK_MODE is forbidden in
# production, so production deploys must provide this.
OPENAI_API_KEY=

# Optional OpenAI-compatible proxy base URL.
OPENAI_BASE_URL=https://polsia.com/ai/openai/v1

# Optional Polsia API key used by the email proxy when that delivery path is enabled.
POLSIA_API_KEY=

# Optional Polsia token alias.
POLSIA_API_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
#
# PostgreSQL connection string. Required in all environments.
DATABASE_URL=

# ── Server ───────────────────────────────────────────────────────────────────
#
# Application base URL — used for email links, Stripe redirects, and CLI endpoints.
# Defaults to https://buildorbit.polsia.app if not set.
APP_URL=https://buildorbit.polsia.app

# Server port — defaults to 3000. Render sets this automatically.
PORT=3000

# Node environment — "production" on Render, "development" locally.
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────────
#
# JWT signing secret. Required. Must be at least 32 bytes.
JWT_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
#
# All transactional emails (magic links, welcome, password reset) go through the
# Polsia email proxy (https://polsia.com/api/proxy/email/send).
# Configure POLSIA_API_KEY or the equivalent production email provider credentials
# in the platform environment.

# ── Billing ───────────────────────────────────────────────────────────────────
#
# Stripe secret key — required for subscription management and Customer Portal.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — verifies webhook events from Stripe.
# Required in production when STRIPE_SECRET_KEY is set (server refuses to boot otherwise).
# If unset in development, webhook signature verification is skipped.
STRIPE_WEBHOOK_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
#
# Required for the GitHub integration (Connect GitHub button in /github settings).
# Create a GitHub OAuth App at https://github.com/settings/developers.
# Set the Authorization callback URL to: https://buildorbit.polsia.app/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Access Control ────────────────────────────────────────────────────────────
#
# Comma-separated list of user IDs that get admin privileges (bootstrapping only).
# Example: ADMIN_USER_IDS=1,2,5
ADMIN_USER_IDS=

# ── Artifact Storage ─────────────────────────────────────────────────────────
#
# local (default) — filesystem ./artifacts (dev only unless mounted on durable disk)
# s3 — S3-compatible object storage (Cloudflare R2, AWS S3, MinIO)
# Production must use ARTIFACT_STORAGE=s3 unless ARTIFACT_LOCAL_DURABLE=true is
# set for a mounted persistent disk. Do not rely on an instance's ephemeral disk.
ARTIFACT_STORAGE=local
# ARTIFACT_LOCAL_PATH=./artifacts
# ARTIFACT_LOCAL_DURABLE=false
#
# Required when ARTIFACT_STORAGE=s3:
# ARTIFACT_S3_BUCKET=
# ARTIFACT_S3_ACCESS_KEY_ID=
# ARTIFACT_S3_SECRET_ACCESS_KEY=
# ARTIFACT_S3_REGION=auto
# ARTIFACT_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# ARTIFACT_S3_PREFIX=artifacts
#
# Rate limiting: postgres (default) or memory (single-instance dev only)
# RATE_LIMIT_BACKEND=memory

# ── Development Only ──────────────────────────────────────────────────────────
#
# Enable mock mode — bypasses auth and mocks Postmark. NEVER set in production
# (server.js enforces this: process throws if NODE_ENV=production and MOCK_MODE=true).
MOCK_MODE=false
